function logEvidence() {
  const desc = document.getElementById('ev-desc').value.trim();
  if (!desc) { showToast('Describe what you did'); return; }
  const item = {
    id: Date.now(),
    desc,
    standard: parseInt(document.getElementById('ev-standard').value),
    standardName: PRINCIPAL_STANDARDS[parseInt(document.getElementById('ev-standard').value)-1]?.name,
    level: document.getElementById('ev-level').value,
    date: document.getElementById('ev-date').value || new Date().toISOString().split('T')[0],
  };
  evidenceLog.push(item);
  document.getElementById('ev-desc').value = '';
  closeModal('modal-add-evidence');
  renderEvidenceLog();
  renderPrincipalStandards();
  updateDashboard();
  showToast('Evidence logged ✓');
}

function renderEvidenceLog() {
  const el = document.getElementById('evidence-log-list');
  if (!evidenceLog.length) {
    el.innerHTML = '<div style="color:var(--muted);font-size:12px;text-align:center;padding:16px">No evidence logged yet.</div>';
    return;
  }
  el.innerHTML = evidenceLog.slice().reverse().slice(0, 8).map(e => `
    <div class="evidence-item">
      <div class="ev-dot" style="background:var(--kelly)"></div>
      <div><div class="ev-text">${e.desc}</div><div class="ev-meta">Standard ${e.standard}: ${e.standardName} · ${e.level} · ${e.date}</div></div>
    </div>`).join('');
}

function renderPrincipalStandards() {
  const el = document.getElementById('principal-standards-list');
  el.innerHTML = PRINCIPAL_STANDARDS.map(s => {
    const items = evidenceLog.filter(e => e.standard === s.num);
    const pct = Math.min(100, items.length * 15);
    const levelCounts = { Aspiring: 0, Emerging: 0, Developing: 0, Transformational: 0 };
    items.forEach(i => levelCounts[i.level] = (levelCounts[i.level] || 0) + 1);
    const topLevel = Object.entries(levelCounts).filter(([,v]) => v > 0).sort(([,a],[,b]) => b-a)[0]?.[0] || 'Aspiring';
    const tagClass = topLevel === 'Transformational' ? 'tag-green' : topLevel === 'Developing' ? 'tag-sage' : topLevel === 'Emerging' ? 'tag-warn' : 'tag-soft';
    return `<div class="growth-card">
      <div class="growth-hd"><div class="growth-name">Standard ${s.num} — ${s.name}</div><span class="tag ${tagClass}">${topLevel}</span></div>
      <div class="bar-row"><div class="bar-track"><div class="bar-fill fill-kelly" style="width:${pct}%"></div></div></div>
      <div style="font-size:11px;color:var(--muted)">${items.length} evidence item${items.length !== 1 ? 's' : ''} · ${s.desc.substring(0,60)}...</div>
    </div>`;
  }).join('');
}

async function generateGrowthPlan() {
  if (!evidenceLog.length) { showToast('Log some evidence first'); return; }
  const summary = PRINCIPAL_STANDARDS.map(s => {
    const items = evidenceLog.filter(e => e.standard === s.num);
    return `Standard ${s.num} (${s.name}): ${items.length} evidence items — ${items.map(e => e.desc).join('; ') || 'none'}`;
  }).join('\n');
  await callAI(AI_SYSTEM,
    `Generate a Missouri Principal Growth Plan for an assistant principal based on this evidence log:\n\n${summary}\n\nFor each of the 5 Principal Standards, write 2-3 sentences in OEQ language describing: current competency level (Aspiring/Emerging/Developing/Transformational), evidence of growth, and one specific growth target for next year. Use professional, formal language appropriate for an official growth plan document.`,
    document.getElementById('growth-ai-output'));
}

