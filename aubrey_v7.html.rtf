let iReadyData = null;

async function handleIReadyFile(file) {
  if (!file) return;
  document.getElementById('iready-upload-icon').textContent = '⏳';
  document.getElementById('iready-upload-title').textContent = 'Processing...';

  let text = '';
  try {
    if (file.name.endsWith('.pdf')) {
      const ab = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const tc = await page.getTextContent();
        text += tc.items.map(s => s.str).join(' ') + '\n';
      }
    } else if (file.name.match(/\.xlsx?|\.csv/i)) {
      const ab = await file.arrayBuffer();
      const wb = XLSX.read(ab, { type: 'array' });
      wb.SheetNames.forEach(sn => {
        text += XLSX.utils.sheet_to_csv(wb.Sheets[sn]) + '\n';
      });
    }
    analyzeIReady(text, file.name);
  } catch(e) {
    document.getElementById('iready-upload-icon').textContent = '⚠️';
    document.getElementById('iready-upload-title').textContent = 'Parse error — try CSV';
    showToast('Could not read iReady file. CSV export works best.');
  }
}

function analyzeIReady(text, fname) {
  // Parse iReady CSV/text — look for student rows with placement data
  const lines = text.split(/[\n\r]+/).filter(l => l.trim());
  const students = [];
  
  // Detect iReady CSV columns: Student, Grade, Reading Placement, Math Placement, etc.
  const headerLine = lines.findIndex(l => 
    /student|name/i.test(l) && (/reading|math|placement|diagnostic/i.test(l))
  );
  
  let readingCol = -1, mathCol = -1, gradeCol = -1, nameCol = -1;
  let readingScoreCol = -1, mathScoreCol = -1;
  
  if (headerLine >= 0) {
    const headers = lines[headerLine].split(',').map(h => h.trim().toLowerCase().replace(/"/g,''));
    nameCol = headers.findIndex(h => h.includes('student') || h.includes('name'));
    gradeCol = headers.findIndex(h => h === 'grade' || h === 'grade level');
    readingCol = headers.findIndex(h => h.includes('reading') && (h.includes('placement') || h.includes('level') || h.includes('grade')));
    mathCol = headers.findIndex(h => h.includes('math') && (h.includes('placement') || h.includes('level') || h.includes('grade')));
    readingScoreCol = headers.findIndex(h => h.includes('reading') && (h.includes('scale') || h.includes('score') || h.includes('lexile')));
    mathScoreCol = headers.findIndex(h => h.includes('math') && h.includes('scale'));
    
    for (let i = headerLine + 1; i < lines.length; i++) {
      const cells = lines[i].split(',').map(c => c.trim().replace(/"/g,''));
      if (cells.length < 3) continue;
      const student = {
        name: nameCol >= 0 ? cells[nameCol] : `Student ${i}`,
        grade: gradeCol >= 0 ? cells[gradeCol] : '?',
        readingLevel: readingCol >= 0 ? cells[readingCol] : null,
        mathLevel: mathCol >= 0 ? cells[mathCol] : null,
        readingScore: readingScoreCol >= 0 ? parseFloat(cells[readingScoreCol]) : null,
        mathScore: mathScoreCol >= 0 ? parseFloat(cells[mathScoreCol]) : null,
      };
      if (student.name && student.name.length > 1) students.push(student);
    }
  }

  // Aggregate placement stats
  const readingStats = { above: 0, on: 0, oneBelow: 0, twoBelow: 0, total: 0 };
  const mathStats = { above: 0, on: 0, oneBelow: 0, twoBelow: 0, total: 0 };
  
  students.forEach(s => {
    if (s.readingLevel) {
      readingStats.total++;
      const lvl = s.readingLevel.toLowerCase();
      if (lvl.includes('above') || lvl.includes('+1') || lvl.includes('2 grade') || lvl.includes('advanced')) readingStats.above++;
      else if (lvl.includes('on') || lvl.includes('level') || lvl.includes('grade level')) readingStats.on++;
      else if (lvl.includes('1') || lvl.includes('one below')) readingStats.oneBelow++;
      else readingStats.twoBelow++;
    }
    if (s.mathLevel) {
      mathStats.total++;
      const lvl = s.mathLevel.toLowerCase();
      if (lvl.includes('above') || lvl.includes('+1') || lvl.includes('advanced')) mathStats.above++;
      else if (lvl.includes('on') || lvl.includes('level') || lvl.includes('grade level')) mathStats.on++;
      else if (lvl.includes('1') || lvl.includes('one below')) mathStats.oneBelow++;
      else mathStats.twoBelow++;
    }
  });

  iReadyData = { students, readingStats, mathStats, rawText: text.slice(0, 3000) };
  
  renderIReadyResults();
  document.getElementById('iready-upload-icon').textContent = '✅';
  document.getElementById('iready-upload-title').textContent = `iReady Loaded — ${students.length || 'data'} ${students.length === 1 ? 'student' : 'students'}`;
  document.getElementById('prof-source-tabs').style.display = 'flex';
  showToast('iReady data loaded ✓');
  
  // Auto-switch to iReady tab if no IC data
  if (!window._stdMap) switchProfTab('iready', null);
}

function renderIReadyResults() {
  if (!iReadyData) return;
  const { students, readingStats, mathStats, rawText } = iReadyData;

  // Reading card
  const rEl = document.getElementById('iready-reading-content');
  if (readingStats.total > 0) {
    const pct = n => Math.round((n / readingStats.total) * 100);
    rEl.innerHTML = `
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--kelly)">On/Above Grade Level</span><span>${pct(readingStats.above + readingStats.on)}%</span></div><div class="bar-track"><div class="bar-fill fill-kelly" style="width:${pct(readingStats.above + readingStats.on)}%"></div></div></div>
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--warn)">One Grade Below</span><span>${pct(readingStats.oneBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-warn" style="width:${pct(readingStats.oneBelow)}%"></div></div></div>
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--danger)">Two+ Grades Below</span><span>${pct(readingStats.twoBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-danger" style="width:${pct(readingStats.twoBelow)}%"></div></div></div>
      <div style="margin-top:8px;font-size:10.5px;color:var(--muted)">${readingStats.total} students · iReady Diagnostic</div>`;
  } else {
    rEl.innerHTML = `<div style="color:var(--muted);font-size:12px">Reading placement columns not detected in file. Try the CSV export from iReady's Diagnostic Results report.</div>`;
  }

  // Math card
  const mEl = document.getElementById('iready-math-content');
  if (mathStats.total > 0) {
    const pct = n => Math.round((n / mathStats.total) * 100);
    mEl.innerHTML = `
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--kelly)">On/Above Grade Level</span><span>${pct(mathStats.above + mathStats.on)}%</span></div><div class="bar-track"><div class="bar-fill fill-kelly" style="width:${pct(mathStats.above + mathStats.on)}%"></div></div></div>
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--warn)">One Grade Below</span><span>${pct(mathStats.oneBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-warn" style="width:${pct(mathStats.oneBelow)}%"></div></div></div>
      <div class="bar-row"><div class="bar-labels"><span style="color:var(--danger)">Two+ Grades Below</span><span>${pct(mathStats.twoBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-danger" style="width:${pct(mathStats.twoBelow)}%"></div></div></div>
      <div style="margin-top:8px;font-size:10.5px;color:var(--muted)">${mathStats.total} students · iReady Diagnostic</div>`;
  } else {
    mEl.innerHTML = `<div style="color:var(--muted);font-size:12px">Math placement columns not detected. Try the CSV export from iReady's Diagnostic Results report.</div>`;
  }

  // Student table
  const sEl = document.getElementById('iready-students-section');
  if (students.length > 0) {
    const flagged = students.filter(s => 
      (s.readingLevel && (s.readingLevel.toLowerCase().includes('two') || s.readingLevel.toLowerCase().includes('2 grade'))) ||
      (s.mathLevel && (s.mathLevel.toLowerCase().includes('two') || s.mathLevel.toLowerCase().includes('2 grade')))
    );
    sEl.innerHTML = `
      <div class="section-hd">Students Flagged — 2+ Grade Levels Below</div>
      ${flagged.length ? `
      <div class="card" style="margin-bottom:16px">
        <table class="result-table">
          <thead><tr><th>Student</th><th>Grade</th><th>Reading Placement</th><th>Math Placement</th></tr></thead>
          <tbody>${flagged.map(s => `<tr><td style="font-weight:600">${s.name}</td><td>${s.grade}</td><td style="color:var(--danger)">${s.readingLevel||'—'}</td><td style="color:var(--danger)">${s.mathLevel||'—'}</td></tr>`).join('')}</tbody>
        </table>
      </div>` : '<div style="background:var(--kelly-fog);border-radius:10px;padding:12px 16px;font-size:12.5px;color:var(--kelly-deep);margin-bottom:16px">✓ No students flagged at 2+ grade levels below based on available data.</div>'}
      <div style="margin-top:4px">
        <button class="btn btn-primary" onclick="generateIReadyAnalysis()">✦ Generate AI iReady Analysis</button>
      </div>`;
  } else {
    sEl.innerHTML = `<div style="margin-top:8px"><button class="btn btn-primary" onclick="generateIReadyAnalysis()">✦ Generate AI Analysis from File Data</button></div>`;
  }
}

