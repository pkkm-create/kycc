function renderSummativeForm(teacher, aiNarrative, ratingRec, growthIndicators) {
  const isNew = teacher.track === 'new';
  const today = new Date().toLocaleDateString('en-US');
  
  // Identify weak standards from observations
  const stdCounts = {};
  teacher.observations.forEach(o => o.standards.forEach(s => { stdCounts[s] = (stdCounts[s]||0)+1; }));
  const allStds = [1,2,3,4,5,6,7,8,9];
  const observedStds = Object.keys(stdCounts).map(Number);
  const weakStds = allStds.filter(s => !observedStds.includes(s) || stdCounts[s] < 2).slice(0,3);
  const strengthStds = observedStds.filter(s => stdCounts[s] >= 2).slice(0,2);

  // Build PD recommendations for weak standards
  const pdRecs = weakStds.map(sNum => {
    const crosswalk = PD_CROSSWALK[sNum];
    if (!crosswalk) return '';
    return `
      <div style="margin-bottom:16px;padding:14px;background:var(--kelly-fog);border-radius:10px;border-left:3px solid var(--kelly)">
        <div style="font-size:11px;font-weight:700;color:var(--kelly-deep);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px">Standard ${sNum}: ${crosswalk.name} — PD Recommendations</div>
        <div style="margin-bottom:8px">
          <div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px">RESEARCH-BASED STRATEGIES</div>
          ${crosswalk.hattie.slice(0,1).map(h => `<div style="font-size:12px;color:var(--text);margin-bottom:3px">🔬 <strong>Hattie:</strong> ${h.name} (${h.effect}) — ${h.tip}</div>`).join('')}
          ${crosswalk.marzano.slice(0,1).map(m => `<div style="font-size:12px;color:var(--text);margin-bottom:3px">📊 <strong>Marzano:</strong> ${m.name} (${m.effect}) — ${m.tip}</div>`).join('')}
          ${crosswalk.tlac.slice(0,1).map(t => `<div style="font-size:12px;color:var(--text);margin-bottom:3px">🏆 <strong>TLAC:</strong> ${t.name} — ${t.tip}</div>`).join('')}
        </div>
        <div>
          <div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px">SUGGESTED PD ACTIONS</div>
          ${crosswalk.pd.map(p => `<div style="font-size:12px;color:var(--text);margin-bottom:2px">· ${p}</div>`).join('')}
        </div>
      </div>`;
  }).join('');

  return `
    <div style="margin-top:16px" id="summative-output-${teacher.id}">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;color:var(--kelly-deep)">Summative Evaluation Package</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-soft btn-sm" onclick="emailSummative(${teacher.id})">📧 Email to Teacher</button>
          <button class="btn btn-soft btn-sm" onclick="downloadSummativePDF(${teacher.id}, '${teacher.name.replace(/'/g,"\\'")}')">⬇️ Download PDF</button>
          <button class="btn btn-soft btn-sm" onclick="printSummative(${teacher.id})">🖨 Print</button>
        </div>
      </div>

      <!-- OFFICIAL FORM -->
      <div class="card mb16" style="border:2px solid var(--kelly)">
        <div class="card-hd" style="background:var(--kelly-deep)">
          <div class="card-title" style="color:#fff">Missouri ${isNew ? 'New Teacher (Yr 1–2)' : 'Veteran Teacher'} Summative Evaluation Form</div>
          <div style="font-size:10px;color:rgba(255,255,255,0.6)">Missouri OEQ Educator Evaluation System</div>
        </div>
        <div class="card-bd">
          <div class="grid2 mb12" style="gap:8px">
            <div style="font-size:12px"><span style="font-weight:700;color:var(--muted);text-transform:uppercase;font-size:10px;letter-spacing:0.5px">Teacher:</span><br>${teacher.name}</div>
            <div style="font-size:12px"><span style="font-weight:700;color:var(--muted);text-transform:uppercase;font-size:10px;letter-spacing:0.5px">Grade/Subject:</span><br>Grade ${teacher.grade} · ${teacher.subject}</div>
