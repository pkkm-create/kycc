function getDailySummaryKey() {
  return 'aubrey_daily_' + new Date().toISOString().slice(0,10);
}
function loadDailySummary() {
  try {
    // Auto-wipe entries older than 24hrs
    const now = Date.now();
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith('aubrey_daily_')) {
        const dateStr = k.replace('aubrey_daily_','');
        const entryDate = new Date(dateStr).getTime();
        if (now - entryDate > 24 * 60 * 60 * 1000) {
          localStorage.removeItem(k);
          i--;
        }
      }
    }
    const saved = localStorage.getItem(getDailySummaryKey());
    return saved ? JSON.parse(saved) : { date: new Date().toISOString().slice(0,10), notes: [], generated: null, timestamp: Date.now() };
  } catch(e) { return { date: new Date().toISOString().slice(0,10), notes: [], generated: null, timestamp: Date.now() }; }
}
function saveDailySummary(data) {
  try { localStorage.setItem(getDailySummaryKey(), JSON.stringify({ ...data, timestamp: Date.now() })); } catch(e) {}
}
function addDailyNote(note) {
  if (!note.trim()) return;
  const data = loadDailySummary();
  data.notes.push({ text: note, time: new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'}) });
  saveDailySummary(data);
  renderDailyWidget();
  updateNotesBadge();
  loadPlannerEvents();
  showToast('Note added ✓'); updateNotesBadge();
  loadPlannerEvents();
}
function clearDailySummary() {
  if (!confirm('Clear today\'s summary notes?')) return;
  localStorage.removeItem(getDailySummaryKey());
  renderDailyWidget();
  updateNotesBadge();
  loadPlannerEvents();
  showToast('Today\'s summary cleared');
}
function renderDailyWidget() {
  const el = document.getElementById('daily-summary-widget');
  if (!el) return;
  const data = loadDailySummary();
  const timeLeft = Math.max(0, Math.floor((24 * 60 * 60 * 1000 - (Date.now() - (data.timestamp || Date.now()))) / (60 * 60 * 1000)));
  el.innerHTML = `
    <div class="card">
      <div class="card-hd">
        <div class="card-title">📋 Today's Summary <span style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0">${data.date}</span></div>
        <div style="display:flex;align-items:center;gap:6px">
          <span style="font-size:10px;color:var(--muted)">⏱ Auto-wipes in ~${timeLeft}h</span>
          <button class="btn btn-soft btn-sm" onclick="generateDailySummaryAI()">✦ AI Summary</button>
          <button class="btn btn-warn btn-sm" onclick="clearDailySummary()">Clear</button>
        </div>
      </div>
      <div class="card-bd">
        <div style="display:flex;gap:8px;margin-bottom:12px">
          <input class="input-field flex1" id="daily-note-input" placeholder="Quick note — observation, meeting, follow-up (no student names)..." style="font-size:13px">
          <button class="btn btn-primary" onclick="addDailyNote(document.getElementById('daily-note-input').value);document.getElementById('daily-note-input').value=''">Add</button>
        </div>
        ${data.notes.length ? `
          <div style="max-height:180px;overflow-y:auto">
            ${data.notes.map((n,i) => `
              <div style="display:flex;align-items:flex-start;gap:8px;padding:7px 0;border-bottom:1px solid var(--border-soft)">
                <span style="font-size:10px;color:var(--muted);flex-shrink:0;margin-top:2px">${n.time}</span>
                <span style="font-size:12.5px;color:var(--text);flex:1">${n.text}</span>
                <button onclick="removeDailyNote(${i})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:14px;flex-shrink:0;padding:0">×</button>
              </div>`).join('')}
          </div>` : '<div style="color:var(--muted);font-size:12px;text-align:center;padding:8px">No notes yet today. Add observations, follow-ups, or reminders above.</div>'}
        ${data.generated ? `<div class="ai-box" style="margin-top:12px"><div style="white-space:pre-wrap;font-size:12px;line-height:1.6">${data.generated}</div></div>` : ''}
        <div style="margin-top:8px;font-size:10px;color:var(--muted)">🔒 Stored on this device only · No student names · Auto-deletes after 24 hours</div>
      </div>
    </div>`;
}
function removeDailyNote(idx) {
  const data = loadDailySummary();
  data.notes.splice(idx, 1);
  saveDailySummary(data);
  renderDailyWidget();
  updateNotesBadge();
  loadPlannerEvents();
}
async function generateDailySummaryAI() {
  const data = loadDailySummary();
  if (!data.notes.length) { showToast('Add some notes first'); return; }
  const el = document.getElementById('daily-summary-widget').querySelector('.ai-box') || (() => {
    const d = document.createElement('div'); d.className = 'ai-box'; d.style.marginTop = '12px';
    document.getElementById('daily-summary-widget').querySelector('.card-bd').appendChild(d); return d;
  })();
  const prompt = `Daily AP notes from ${data.date}:\n${data.notes.map(n => `${n.time}: ${n.text}`).join('\n')}\n\nGenerate a brief end-of-day summary (3-5 sentences) identifying: key themes, any follow-up actions needed, and one reflection on leadership practice. Professional tone. No student names used.`;
  const result = await callAI(AI_SYSTEM, prompt, null);
  if (result) {
    data.generated = result;
    saveDailySummary(data);
    renderDailyWidget();
  updateNotesBadge();
  loadPlannerEvents();
  }
}

