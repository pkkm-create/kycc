let currentFilter = 'all';
function renderStandards(filter) {
  currentFilter = filter;
  const grid = document.getElementById('standards-grid');
  const query = document.getElementById('standards-search')?.value.toLowerCase() || '';
  const gradeFilter = document.getElementById('std-grade-filter')?.value || 'all';

  // Combine all standards — K-5, 6-12 Math, 6-12 ELA
  const allStandards = [
    ...MLS_STANDARDS,
    ...MLS_MATH_6_12,
    ...MLS_ELA_6_12
  ];

  const filtered = allStandards.filter(s => {
    const subjectMatch = filter === 'all' || s.subject === filter;
    const gradeMatch = gradeFilter === 'all' ||
      (gradeFilter === 'K-5' && (s.grades === 'K–5' || s.grades === 'K' || s.grades === '1–5' || s.grades === 'K–3' || s.grades === '3–5')) ||
      (gradeFilter === '6-8' && (s.grades === '6–8' || s.grades === '6' || s.grades === '7' || s.grades === '8' || s.grades === '6–12')) ||
      (gradeFilter === '9-12' && (s.grades === '9–12' || s.grades === 'HS' || s.grades === '6–12')) ||
      (gradeFilter === '6-12' && (s.grades === '6–8' || s.grades === '9–12' || s.grades === 'HS' || s.grades === '6' || s.grades === '7' || s.grades === '8' || s.grades === '6–12'));
    const searchMatch = !query || s.code.toLowerCase().includes(query) || s.desc.toLowerCase().includes(query) ||
      (s.l3 && s.l3.toLowerCase().includes(query)) || (s.domain && s.domain.toLowerCase().includes(query));
    return subjectMatch && gradeMatch && searchMatch;
  });

  if (!filtered.length) {
    grid.innerHTML = '<div style="color:var(--muted);font-size:12.5px;grid-column:1/-1">No standards match your search.</div>';
    return;
  }
