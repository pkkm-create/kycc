  const hasIC = window._stdMap && Object.keys(window._stdMap).length > 0;
  const hasIR = iReadyData && iReadyData.students.length > 0;
  
  if (!hasIC && !hasIR) {
    el.innerHTML = '<div style="color:var(--muted);font-size:12.5px;text-align:center;padding:24px">Upload both IC and iReady data to see the combined view.</div>';
    return;
  }
  
  let html = '<div class="grid2" style="margin-bottom:16px">';
  
  if (hasIC) {
    const topGaps = Object.values(window._stdMap).sort((a,b) => (b.counts[0]/Math.max(b.total,1)) - (a.counts[0]/Math.max(a.total,1))).slice(0,3);
    html += `<div><div class="section-hd" style="font-size:13px">IC — Top Gaps by Standard</div>${topGaps.map(s => stdCardHTML(s)).join('')}</div>`;
  }
  
