function renderRoster() {
  const el = document.getElementById('teacher-roster');
  if (!teachers.length) {
    el.innerHTML = '<div style="color:var(--muted);font-size:12.5px;text-align:center;padding:30px;border:1.5px dashed var(--border);border-radius:12px">No teachers added yet.<br><span style="font-size:11px">Click "+ Add Teacher" above.</span></div>';
    return;
  }
  el.innerHTML = teachers.map(t => {
    const statusClass = evalStatus(t).cls;
    const statusLabel = evalStatus(t).label;
    return `<div class="t-row" onclick="openObsPanel(${t.id})">
      <div class="t-av" style="${statusClass === 'st-over' ? 'background:linear-gradient(135deg,#D47070,#B85555)' : statusClass === 'st-due' ? 'background:linear-gradient(135deg,#E0A060,#C4863A)' : ''}">${t.name.split(' ').map(w=>w[0]).join('').slice(0,2)}</div>
      <div><div class="t-name">${t.name}</div><div class="t-sub">${t.grade !== 'Multi' ? 'Grade ' + t.grade : 'Multi-Grade'} · ${t.subject || 'All'} · ${t.track === 'new' ? 'New Teacher' : 'Veteran'} · ${t.obsType === 'co' ? 'Co-Obs' : 'Solo'}</div></div>
      <div class="t-status ${statusClass}">${statusLabel}</div>
    </div>`;
  }).join('');
}

function evalStatus(t) {
  if (!t.due) return { cls:'st-ok', label:'No Date Set' };
  const due = new Date(t.due);
  const today = new Date();
  const diff = Math.ceil((due - today) / (1000*60*60*24));
  if (diff < 0) return { cls:'st-over', label:'Overdue' };
  if (diff <= 14) return { cls:'st-due', label:`Due in ${diff}d` };
  return { cls:'st-ok', label:'On Track' };
}

function openObsPanel(tid) {
  activeTeacher = teachers.find(t => t.id === tid);
  if (!activeTeacher) return;
  showModal('modal-observation');
  document.getElementById('obs-modal-title').textContent = `Observation — ${activeTeacher.name}`;
  document.getElementById('obs-date').valueAsDate = new Date();
  document.getElementById('obs-ai-output').innerHTML = '';

  // Build standards checklist
  const cl = document.getElementById('obs-standards-checklist');
  cl.innerHTML = MO_STANDARDS.map(s =>
    `<label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text);cursor:pointer">
      <input type="checkbox" class="obs-std-check" value="${s.num}" style="accent-color:var(--kelly)"> Std ${s.num}: ${s.short}
    </label>`
  ).join('');
}

function saveObservation() {
  if (!activeTeacher) return;
  const notes = document.getElementById('obs-notes').value.trim();
  const date = document.getElementById('obs-date').value;
  const duration = document.getElementById('obs-duration').value;
  const checkedStds = [...document.querySelectorAll('.obs-std-check:checked')].map(c => parseInt(c.value));

  activeTeacher.observations.push({ date, duration, notes, standards: checkedStds, timestamp: Date.now() });
  closeModal('modal-observation');
