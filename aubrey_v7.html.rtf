  document.getElementById('prof-results').style.display = tab === 'ic' ? 'block' : 'none';
  document.getElementById('iready-results').style.display = tab === 'iready' ? 'block' : 'none';
  document.getElementById('combined-results').style.display = tab === 'combined' ? 'block' : 'none';
