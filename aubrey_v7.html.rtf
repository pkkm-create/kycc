async function generateSummative() {
  if (!activeTeacher || !activeTeacher.observations.length) { showToast('Add at least one observation first'); return; }
  const obsText = activeTeacher.observations.map((o,i) => `Observation ${i+1} (${o.date}, ${o.duration}): ${o.notes}`).join('\n\n');
  const isNew = activeTeacher.track === 'new';
  
  const obsPanel = document.getElementById('obs-panel');
  
  // Remove old summative if exists
  const oldOut = document.getElementById(`summative-output-${activeTeacher.id}`);
  if (oldOut) oldOut.remove();

  const prompt = `Generate a Missouri OEQ summative evaluation narrative for a ${isNew ? 'Year 1-2 new' : 'veteran'} teacher in Grade ${activeTeacher.grade} (${activeTeacher.subject}). Based on ${activeTeacher.observations.length} observations:\n\n${obsText}\n\nReturn ONLY a JSON object with these exact keys (no markdown, no backticks):\n{"narrative":"4-5 sentence professional narrative in Missouri OEQ language","rating":"one of: Ineffective, Minimally Effective, Effective, Highly Effective","growthIndicators":["indicator 1","indicator 2"]}`;

  const loadDiv = document.createElement('div');
  loadDiv.innerHTML = '<div class="ai-box"><span class="spinner"></span>Generating summative package...</div>';
  obsPanel.appendChild(loadDiv);

  let narrative = '', rating = 'Effective', growthIndicators = [];
  
  if (config.worker) {
    try {
      const res = await fetch('https://kylee-ap-proxy.eduadmin.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ system: AI_SYSTEM, messages: [{ role: 'user', content: prompt }] })
      });
      const data = await res.json();
      const text = (data.content || []).filter(b => b.type === 'text').map(b => b.text).join('').replace(/```json|```/g,'').trim();
      try {
        const parsed = JSON.parse(text);
        narrative = parsed.narrative || '';
        rating = parsed.rating || 'Effective';
        growthIndicators = parsed.growthIndicators || [];
      } catch(e) { narrative = text; rating = 'Effective'; }
    } catch(e) { narrative = 'AI unavailable — please add observation notes and generate manually.'; }
  } else {
    narrative = 'Configure your Worker URL in School Setup to generate AI narrative.';
  }

  loadDiv.remove();
  obsPanel.insertAdjacentHTML('beforeend', renderSummativeForm(activeTeacher, narrative, rating, growthIndicators));
}

function printSummative(tid) {
  const el = document.getElementById(`summative-output-${tid}`);
  if (!el) return;
  const win = window.open('', '_blank');
  win.document.write(`<html><head><title>Summative Evaluation</title><style>body{font-family:Arial,sans-serif;padding:20px;max-width:800px;margin:0 auto}*{box-sizing:border-box}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}.divider{height:1px;background:#ddd;margin:12px 0}</style></head><body>${el.innerHTML}</body></html>`);
  win.document.close();
  win.print();
}

function emailSummative(tid) {
  const teacher = teachers.find(t => t.id === tid);
  if (!teacher) return;
  const el = document.getElementById(`summative-output-${tid}`);
  if (!el) return;

  // Strip HTML tags for plain text email body
  const plainText = el.innerText || el.textContent;
  const subject = encodeURIComponent(`Summative Evaluation — ${teacher.name} — ${config.year || '2025-26'}`);
  const body = encodeURIComponent(
    `Dear ${teacher.name},\n\nPlease find your summative evaluation summary below. A formal copy will follow through official district channels.\n\n` +
    `─────────────────────────────────\n` +
    plainText.substring(0, 1800) +
    `\n─────────────────────────────────\n\n` +
    `Please review and reach out if you have any questions. I look forward to discussing this with you.\n\n` +
    `${config.name || 'Your Evaluator'}\n${config.school || ''}`
  );

  window.location.href = `mailto:?subject=${subject}&body=${body}`;
}

