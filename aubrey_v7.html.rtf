  const cycle = {
    id: Date.now(),
    teacher,
    focus: document.getElementById('nc-focus').value,
    research: document.getElementById('nc-research').value,
    obsCount: parseInt(document.getElementById('nc-obs-count').value),
    start: document.getElementById('nc-start').value,
