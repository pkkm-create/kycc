pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

const MLS_MAP = {
  'rl.1':'RL.1-3','rl.2':'RL.1-3','rl.3':'RL.1-3','rl.4':'RL.4-6','rl.5':'RL.4-6','rl.6':'RL.4-6',
  'ri.1':'RI.1-2','ri.2':'RI.1-2','ri.5':'RI.5-8','ri.6':'RI.5-8','ri.7':'RI.5-8','ri.8':'RI.5-8',
  'rf.2':'RF.2-3','rf.3':'RF.2-3','rf.4':'RF.4',
  'w.1':'W.1','w.2':'W.2','w.3':'W.3',
  'l.1':'L.1-2','l.2':'L.1-2','l.4':'L.4-6','l.5':'L.4-6','l.6':'L.4-6',
  'oa':'OA','nbt':'NBT','nf':'NF','md':'MD','geo':'G','geometry':'G','fractions':'NF',
  'ps1':'K-5.PS1','ps2':'K-5.PS2','ls1':'K-5.LS1','ess':'K-5.ESS','ets':'K-5.ETS',
  'pc.1':'PC.1','ss.2':'SS.2','ss.3':'SS.3','ss.4':'SS.4','ri.6ss':'RI.6','ts.7':'TS.7',
};

async function handleProfFile(file) {
  if (!file) return;
  document.getElementById('prof-empty').style.display = 'none';
  document.getElementById('prof-results').style.display = 'none';
  document.getElementById('prof-processing').style.display = 'block';

  let text = '';
  try {
    if (file.name.endsWith('.pdf')) {
      const ab = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const tc = await page.getTextContent();
        text += tc.items.map(s => s.str).join(' ') + '\n';
      }
    } else if (file.name.match(/\.xlsx?|\.csv/i)) {
      const ab = await file.arrayBuffer();
      const wb = XLSX.read(ab, { type: 'array' });
      wb.SheetNames.forEach(sn => {
        const ws = wb.Sheets[sn];
        text += XLSX.utils.sheet_to_csv(ws) + '\n';
      });
    }
    analyzeText(text, file.name);
  } catch(e) {
    document.getElementById('prof-processing').style.display = 'none';
    document.getElementById('prof-empty').style.display = 'block';
    showToast('Could not parse file. Try CSV or ensure PDF is text-based.');
  }
}

function analyzeText(text, fname) {
  const lines = text.split(/[\n\r]+/).filter(l => l.trim());
  const gradeMap = {};
  const stdMap = {};

  lines.forEach(line => {
    const gradeMatch = line.match(/\b([K1-5])(?:th|st|nd|rd)?\s*(?:Grade|Gr\.?)/i);
    const grade = gradeMatch ? gradeMatch[1].toUpperCase() : 'All';

    // Find MLS code
    let mlsCode = null;
    const lower = line.toLowerCase();
    for (const [key, code] of Object.entries(MLS_MAP)) {
      if (lower.includes(key)) { mlsCode = code; break; }
    }
    if (!mlsCode) return;

    // Find score
    const scoreMatch = line.match(/(\d+(?:\.\d+)?)\s*%?|(\d+)\s*\/\s*(\d+)/);
    if (!scoreMatch) return;
    let score = parseFloat(scoreMatch[1]);
    if (scoreMatch[2] && scoreMatch[3]) score = (parseInt(scoreMatch[2]) / parseInt(scoreMatch[3])) * 100;
    if (isNaN(score) || score > 100) return;

    const level = score >= 80 ? 4 : score >= 60 ? 3 : score >= 40 ? 2 : 1;
    const key = `${grade}|${mlsCode}`;
    if (!stdMap[key]) stdMap[key] = { grade, code: mlsCode, counts: [0,0,0,0], total: 0 };
    stdMap[key].counts[level-1]++;
    stdMap[key].total++;
    if (!gradeMap[grade]) gradeMap[grade] = [];
    if (!gradeMap[grade].includes(mlsCode)) gradeMap[grade].push(mlsCode);
  });

  document.getElementById('prof-processing').style.display = 'none';

  if (Object.keys(stdMap).length === 0) {
    showToast('No MLS standards detected. Make sure assignment names include standard codes.');
    document.getElementById('prof-empty').style.display = 'block';
    return;
  }

  document.getElementById('prof-results').style.display = 'block';
  renderProfTabs(gradeMap, stdMap);
  updateBadge('badge-prof', Object.keys(stdMap).length);
}

function renderProfTabs(gradeMap, stdMap) {
  const tabEl = document.getElementById('prof-grade-tabs');
  const grades = ['All', ...Object.keys(gradeMap).sort()];
  tabEl.innerHTML = grades.map((g, i) => `<div class="tab ${i===0?'active':''}" onclick="filterProfGrade('${g}',this)">${g === 'All' ? 'All Grades' : 'Grade ' + g}</div>`).join('');
  window._stdMap = stdMap;
  window._gradeMap = gradeMap;
  renderProfGrid('All', stdMap);
}

function filterProfGrade(grade, el) {
  document.querySelectorAll('#prof-grade-tabs .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderProfGrid(grade, window._stdMap);
}

function renderProfGrid(grade, stdMap) {
  const grid = document.getElementById('prof-results-grid');
  const entries = Object.values(stdMap).filter(e => grade === 'All' || e.grade === grade);
  if (!entries.length) { grid.innerHTML = '<div style="color:var(--muted);font-size:12.5px">No data for this grade.</div>'; return; }

  const sorted = entries.sort((a,b) => (a.counts[0]/Math.max(a.total,1)) - (b.counts[0]/Math.max(b.total,1))).reverse();
  grid.innerHTML = `<div>${sorted.slice(0, Math.ceil(sorted.length/2)).map(s => stdCardHTML(s)).join('')}</div><div>${sorted.slice(Math.ceil(sorted.length/2)).map(s => stdCardHTML(s)).join('')}</div>`;

  // AI analysis for top gap
  const topGap = sorted[0];
  if (topGap) {
    const pct1 = Math.round((topGap.counts[0]/topGap.total)*100);
    const pct2 = Math.round((topGap.counts[1]/topGap.total)*100);
    const aiSec = document.getElementById('prof-ai-section');
    const stdInfo = MLS_STANDARDS.find(s => s.code === topGap.code) || {};
    callAI(AI_SYSTEM, 
      `Grade ${topGap.grade} class data shows ${topGap.code} (${stdInfo.desc || topGap.code}): ${pct1}% at Level 1, ${pct2}% at Level 2, ${Math.round((topGap.counts[2]/topGap.total)*100)}% at Level 3, ${Math.round((topGap.counts[3]/topGap.total)*100)}% at Level 4. Provide: 1) Root cause hypothesis 2) Specific intervention recommendation 3) Research connection to Hattie, Marzano, or TLAC 4) Suggested coaching conversation focus. Be concise — 3-4 sentences max per section.`,
      aiSec);
  }
}

function stdCardHTML(s) {
  const t = s.total;
  const p = i => t ? Math.round((s.counts[i]/t)*100) : 0;
  const stdInfo = MLS_STANDARDS.find(x => x.code === s.code) || {};
  return `<div class="std-card">
    <div class="std-code">${s.code} · Grade ${s.grade}</div>
    <div class="std-desc">${stdInfo.desc || s.code}</div>
    <div class="level-row">
      <div class="lp l4">L4 · ${p(3)}%</div><div class="lp l3">L3 · ${p(2)}%</div><div class="lp l2">L2 · ${p(1)}%</div><div class="lp l1">L1 · ${p(0)}%</div>
    </div>
  </div>`;
}

