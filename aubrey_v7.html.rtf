async function coachingAI(cid) {
  const c = coachingCycles.find(x => x.id === cid);
  if (!c) return;
  const research = c.research === 'all' ? 'Hattie, Marzano, and Teach Like a Champion' : c.research === 'hattie' ? 'Hattie Visible Learning' : c.research === 'marzano' ? 'Marzano Art & Science of Teaching' : 'Teach Like a Champion by Lemov';
  await callAI(AI_SYSTEM,
    `I'm coaching ${c.teacher} with a focus on: "${c.focus}". This is observation ${c.obsCompleted + 1} of ${c.obsCount}. Please recommend: 1) One specific strategy from ${research} (include effect size or technique number) 2) A coaching question to open the conversation 3) What to look for in the next observation. Be concise.`,
    document.getElementById(`coaching-ai-${cid}`));
}

function c_obs(cid) {
  const c = coachingCycles.find(x => x.id === cid);
  if (c && c.obsCompleted < c.obsCount) { c.obsCompleted++; renderCoachingCycles(); showToast('Observation logged ✓'); }
}

function findStrategy() {
  const query = document.getElementById('strategy-search').value.toLowerCase();
  if (!query.trim()) return;
  const allStrategies = [...HATTIE_STRATEGIES, ...MARZANO_STRATEGIES, ...TLAC_STRATEGIES];
  const relevant = allStrategies.filter(s =>
    s.name.toLowerCase().includes(query) || s.desc.toLowerCase().includes(query) || query.split(' ').some(w => s.desc.toLowerCase().includes(w))
  ).slice(0, 4);

  if (relevant.length === 0) {
    document.getElementById('strategy-results').innerHTML = '<div style="color:var(--muted);font-size:12.5px">No matching strategies. Try different keywords.</div>';
    // Fall back to AI
    callAI(AI_SYSTEM, `I observed: "${document.getElementById('strategy-search').value}". Recommend 2 specific coaching strategies from Hattie, Marzano, or Teach Like a Champion to address this. Include effect size or technique number. Be specific and actionable.`,
      document.getElementById('strategy-results'));
    return;
  }

  document.getElementById('strategy-results').innerHTML = relevant.map(s => `
    <div class="coach-card">
      <div class="coach-hd"><div style="font-size:12.5px;font-weight:700;color:var(--text)">${s.name} · ${s.effect}</div><span class="res-tag rt-${s.tag}">${s.tag.charAt(0).toUpperCase()+s.tag.slice(1)}</span></div>
      <div class="coach-bd">${s.desc}</div>
    </div>`).join('');
}

