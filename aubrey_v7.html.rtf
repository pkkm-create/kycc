function saveConfig() {
  config.school = document.getElementById('cfg-school').value;
  config.district = document.getElementById('cfg-district').value;
  config.principal = document.getElementById('cfg-principal').value;
  config.mascot = document.getElementById('cfg-mascot').value;
  config.assessment = document.getElementById('cfg-assessment').value;
  config.worker = document.getElementById('cfg-worker').value.trim();
  config.year = document.getElementById('cfg-year').value;
  config.name = document.getElementById('cfg-name').value;
  try { localStorage.setItem('aubrey_config', JSON.stringify(config)); } catch(e){}
  document.getElementById('chip-school').textContent = config.school || '—';
  document.getElementById('chip-year').textContent = config.year || '2025–26';
  // Update sidebar name live
  const sbName = document.getElementById('sb-name-el');
  if (sbName && config.name) sbName.textContent = config.name;
  const sbInitials = document.getElementById('sb-initials-el');
  if (sbInitials && config.name) sbInitials.textContent = config.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
  showToast('Settings saved ✓ — they\'ll reload automatically next time');
}

function loadConfig() {
  try {
    const saved = localStorage.getItem('aubrey_config');
    if (saved) {
      config = { ...config, ...JSON.parse(saved) };
      document.getElementById('cfg-school').value = config.school || '';
      document.getElementById('cfg-district').value = config.district || '';
      document.getElementById('cfg-principal').value = config.principal || '';
      document.getElementById('cfg-mascot').value = config.mascot || '';
      document.getElementById('cfg-assessment').value = config.assessment || '';
      document.getElementById('cfg-worker').value = config.worker || 'https://kylee-ap-proxy.eduadmin.workers.dev';
      document.getElementById('cfg-year').value = config.year || '2025–26';
      document.getElementById('cfg-name').value = config.name || 'Aubrey';
      document.getElementById('chip-school').textContent = config.school || '—';
      document.getElementById('chip-year').textContent = config.year || '2025–26';
      // Update sidebar name
      const sbName = document.getElementById('sb-name-el');
      if (sbName && config.name) sbName.textContent = config.name;
      const sbInitials = document.getElementById('sb-initials-el');
      if (sbInitials && config.name) sbInitials.textContent = config.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    }
  } catch(e){}
}

