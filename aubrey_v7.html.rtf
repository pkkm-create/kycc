    status: 'Active',
  };
  coachingCycles.push(cycle);
  closeModal('modal-new-cycle');
  document.getElementById('nc-teacher').value = '';
  document.getElementById('nc-focus').value = '';
  renderCoachingCycles();
  updateDashboard();
