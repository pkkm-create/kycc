  const el = document.getElementById('combined-ai-section');
  const icSummary = Object.values(window._stdMap||{}).map(s => `${s.code} Gr${s.grade}: L1=${s.counts[0]},L2=${s.counts[1]},L3=${s.counts[2]},L4=${s.counts[3]}`).join(' | ');
