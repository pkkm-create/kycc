// ─────────────────────────────────────────────
async function callAI(systemPrompt, userMessage, targetEl) {
  if (!config.worker) {
    if (targetEl) targetEl.innerHTML = '<div class="ai-box">⚠️ No Worker URL configured. Go to School Setup and paste your Cloudflare Worker URL to enable AI features.</div>';
    return null;
  }
  if (targetEl) targetEl.innerHTML = '<div class="ai-box"><span class="spinner"></span>Generating...</div>';
  try {
    const res = await fetch('https://kylee-ap-proxy.eduadmin.workers.dev', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ system: systemPrompt, messages: [{ role: 'user', content: userMessage }] })
    });
    const data = await res.json();
    const text = (data.content || []).filter(b => b.type === 'text').map(b => b.text).join('');
    if (targetEl && text) {
      targetEl.innerHTML = `<div class="ai-box"><div style="white-space:pre-wrap;font-size:12.5px">${text}</div></div>`;
    }
    return text;
  } catch (e) {
    if (targetEl) targetEl.innerHTML = '<div class="ai-box">⚠️ AI request failed. Check your Worker URL in School Setup.</div>';
    return null;
  }
}

