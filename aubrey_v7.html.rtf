function updateDashboard() {
  // Tile counts
  const bEl = document.getElementById('ds-behaviors');
  const eEl = document.getElementById('ds-evals');
  const nEl = document.getElementById('ds-notes');
  const evEl = document.getElementById('ds-evidence');
  if (bEl) bEl.textContent = incidents.length;
  if (eEl) eEl.textContent = teachers.length;
  const nd = loadDailySummary();
  if (nEl) nEl.textContent = nd.notes.length;
  if (evEl) evEl.textContent = evidenceLog.length;

  // Behavior hint
  const bHint = document.getElementById('ds-behaviors-hint');
  if (bHint) {
    const flagged = (() => { const c={}; incidents.forEach(i=>{c[i.code]=(c[i.code]||0)+1;}); return Object.values(c).filter(v=>v>=3).length; })();
    bHint.textContent = flagged > 0 ? flagged + ' student' + (flagged!==1?'s':'') + ' flagged' : incidents.length + ' this session';
  }
  // Eval hint
  const eHint = document.getElementById('ds-evals-hint');
  if (eHint) {
    const needAction = teachers.filter(t => ['st-over','st-due'].includes(evalStatus(t).cls)).length;
    eHint.textContent = needAction > 0 ? needAction + ' need' + (needAction===1?'s':'') + ' action' : 'All on track';
  }
  // Evidence hint
  const evHint = document.getElementById('ds-evidence-hint');
  if (evHint) evHint.textContent = evidenceLog.length + ' total logged';

  // Greeting
  const hr = new Date().getHours();
  const greet = hr < 12 ? 'Good morning' : hr < 17 ? 'Good afternoon' : 'Good evening';
  const gEl = document.getElementById('dash-greeting');
  if (gEl) gEl.textContent = greet + ', Aubrey.'

  // Date
  const d = new Date();
  const dateEl = document.getElementById('dash-date');
  if (dateEl) dateEl.textContent = d.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'}).toUpperCase();

  // Eval list → glance
  const evalEl = document.getElementById('dash-eval-list');
  if (evalEl) {
    if (teachers.length) {
      const upcoming = teachers.slice(0,3).map(t => {
        const st = evalStatus(t);
        return `<div class="g-row">
          <div class="g-dot" style="background:${st.cls==='st-ok'?'#4CAF50':st.cls==='st-due'?'#C4863A':'#B85555'}"></div>
          <div class="g-time">${t.grade ? 'Gr. '+t.grade : 'K–5'}</div>
          <div class="g-text">${t.name} · <span style="color:${st.cls==='st-ok'?'#4CAF50':st.cls==='st-due'?'#C4863A':'#B85555'};font-weight:600">${st.label}</span></div>
        </div>`;
      }).join('');
      evalEl.innerHTML = upcoming;
    } else {
      evalEl.innerHTML = '<div class="g-row"><div class="g-dot" style="background:#D6CCAA"></div><div class="g-time">—</div><div class="g-text" style="color:#7a9080">Add teachers in Evaluations to see upcoming activity</div></div>';
    }
  }
}

