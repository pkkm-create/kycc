function addTeacher() {
  const name = document.getElementById('at-name').value.trim();
  if (!name) { showToast('Enter teacher name'); return; }
  const teacher = {
    id: Date.now(),
    name,
    grade: document.getElementById('at-grade').value,
    subject: document.getElementById('at-subject').value,
    track: document.getElementById('at-track').value,
    obsType: document.getElementById('at-obstype').value,
    due: document.getElementById('at-due').value,
    observations: [],
    stdRatings: {},
    overallRating: null,
  };
  teachers.push(teacher);
  document.getElementById('at-name').value = '';
  document.getElementById('at-subject').value = '';
  closeModal('modal-add-teacher');
  renderRoster();
  updateDashboard();
  updateBadge('badge-eval', teachers.length);
