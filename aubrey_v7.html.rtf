    html += `<div><div class="section-hd" style="font-size:13px">iReady — Placement Summary</div>
      <div class="card" style="margin-bottom:9px"><div class="card-bd">
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Reading</div>
        <div class="bar-row"><div class="bar-labels"><span>On/Above</span><span>${rPct(readingStats.above+readingStats.on)}%</span></div><div class="bar-track"><div class="bar-fill fill-kelly" style="width:${rPct(readingStats.above+readingStats.on)}%"></div></div></div>
        <div class="bar-row"><div class="bar-labels"><span>1 Grade Below</span><span>${rPct(readingStats.oneBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-warn" style="width:${rPct(readingStats.oneBelow)}%"></div></div></div>
        <div class="bar-row"><div class="bar-labels"><span>2+ Below</span><span>${rPct(readingStats.twoBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-danger" style="width:${rPct(readingStats.twoBelow)}%"></div></div></div>
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin:12px 0 8px">Math</div>
        <div class="bar-row"><div class="bar-labels"><span>On/Above</span><span>${mPct(mathStats.above+mathStats.on)}%</span></div><div class="bar-track"><div class="bar-fill fill-kelly" style="width:${mPct(mathStats.above+mathStats.on)}%"></div></div></div>
        <div class="bar-row"><div class="bar-labels"><span>1 Grade Below</span><span>${mPct(mathStats.oneBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-warn" style="width:${mPct(mathStats.oneBelow)}%"></div></div></div>
        <div class="bar-row"><div class="bar-labels"><span>2+ Below</span><span>${mPct(mathStats.twoBelow)}%</span></div><div class="bar-track"><div class="bar-fill fill-danger" style="width:${mPct(mathStats.twoBelow)}%"></div></div></div>
      </div></div>
    </div>`;
  }
  
  html += '</div>';
  
  if (hasIC && hasIR) {
    html += `<button class="btn btn-primary" onclick="generateCombinedAnalysis()">✦ Generate Full IC + iReady AI Analysis</button>
    <div id="combined-ai-section" style="margin-top:12px"></div>`;
  }
  
  el.innerHTML = html;
}

