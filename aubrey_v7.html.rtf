const PLANNER_KEY = 'aubrey_planner_v1';
let plannerEvents = [];
let plannerMonthOffset = 0;
let plannerWeekOffset = 0;
let plannerDayOffset = 0;

const EV_COLORS = {
  general:'var(--euca)', meeting:'#6B7C93', deadline:'var(--danger)',
  personal:'var(--warn)', pd:'var(--sage)', observation:'var(--euca-deep)',
  parent:'#4A5E6E', student:'#3D6B30'
};
const EV_LABELS = {
  general:'General', meeting:'Meeting', deadline:'Deadline', personal:'Personal',
  pd:'PD', observation:'Observation', parent:'Parent', student:'Student Support'
};

function loadPlannerEvents() {
  try {
    const saved = localStorage.getItem(PLANNER_KEY);
    plannerEvents = saved ? JSON.parse(saved) : [];
  } catch(e) { plannerEvents = []; }
}
function savePlannerEvents() {
  try { localStorage.setItem(PLANNER_KEY, JSON.stringify(plannerEvents)); } catch(e) {}
}

function saveEvent() {
  const title = document.getElementById('ev-title').value.trim();
  const date = document.getElementById('ev-plan-date').value;
  if (!title || !date) { showToast('Title and date are required'); return; }
  const ev = {
    id: Date.now(),
    title,
    date,
    time: document.getElementById('ev-time').value || '',
    endTime: document.getElementById('ev-end-time').value || '',
    type: document.getElementById('ev-type').value,
    notes: document.getElementById('ev-notes').value.trim(),
    repeat: document.getElementById('ev-repeat').value,
  };
  loadPlannerEvents();
  plannerEvents.push(ev);
  savePlannerEvents();
  closeModal('modal-add-event');
  // Reset form
  ['ev-title','ev-time','ev-end-time','ev-notes'].forEach(id => { const el = document.getElementById(id); if(el) el.value=''; });
  document.getElementById('ev-repeat').value = 'none';
  renderPlanner();
  showToast('Event saved ✓');
}

function deleteEvent(id) {
  loadPlannerEvents();
  plannerEvents = plannerEvents.filter(e => e.id !== id);
  savePlannerEvents();
  closeModal('modal-event-detail');
  renderPlanner();
  showToast('Event deleted');
}

function getEventsForDate(dateStr) {
  loadPlannerEvents();
  const d = new Date(dateStr + 'T00:00:00');
  return plannerEvents.filter(ev => {
    if (ev.date === dateStr) return true;
    if (ev.repeat === 'daily') return new Date(ev.date + 'T00:00:00') <= d;
    if (ev.repeat === 'weekly') {
      const orig = new Date(ev.date + 'T00:00:00');
      return orig <= d && orig.getDay() === d.getDay();
    }
    if (ev.repeat === 'monthly') {
      const orig = new Date(ev.date + 'T00:00:00');
      return orig <= d && orig.getDate() === d.getDate();
    }
    return false;
  }).sort((a,b) => (a.time||'').localeCompare(b.time||''));
}

function formatDateStr(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

// ── MONTH VIEW
function renderMonthView() {
  const today = new Date();
  const ref = new Date(today.getFullYear(), today.getMonth() + plannerMonthOffset, 1);
  const label = ref.toLocaleDateString('en-US', {month:'long', year:'numeric'});
  document.getElementById('month-label').textContent = label;

  const hdr = document.getElementById('month-grid-header');
  const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  hdr.innerHTML = days.map(d => `<div class="planner-month-day-hd">${d}</div>`).join('');

  const grid = document.getElementById('month-grid');
  const firstDay = ref.getDay();
  const daysInMonth = new Date(ref.getFullYear(), ref.getMonth()+1, 0).getDate();
  const prevDays = new Date(ref.getFullYear(), ref.getMonth(), 0).getDate();
  const todayStr = formatDateStr(today);

  let cells = '';
  // Prev month padding
  for (let i = firstDay - 1; i >= 0; i--) {
    const d = new Date(ref.getFullYear(), ref.getMonth()-1, prevDays-i);
    cells += `<div class="planner-day other-month"><div class="planner-day-num">${prevDays-i}</div></div>`;
  }
  // This month
  for (let d = 1; d <= daysInMonth; d++) {
    const dateObj = new Date(ref.getFullYear(), ref.getMonth(), d);
    const dateStr = formatDateStr(dateObj);
    const evs = getEventsForDate(dateStr);
    const isToday = dateStr === todayStr;
    const evHTML = evs.slice(0,3).map(e =>
      `<div class="planner-day-event ev-${e.type}" title="${e.title}">${e.time ? e.time.slice(0,5)+' ' : ''}${e.title}</div>`
    ).join('');
    const more = evs.length > 3 ? `<div style="font-size:8px;color:var(--muted)">+${evs.length-3} more</div>` : '';
    cells += `<div class="planner-day ${isToday?'today':''} ${evs.length?'has-events':''}" onclick="jumpToDay('${dateStr}')">
      <div class="planner-day-num">${d}</div>${evHTML}${more}</div>`;
  }
  // Next month padding
  const totalCells = Math.ceil((firstDay + daysInMonth) / 7) * 7;
  for (let d = 1; d <= totalCells - firstDay - daysInMonth; d++) {
    cells += `<div class="planner-day other-month"><div class="planner-day-num">${d}</div></div>`;
  }
  grid.innerHTML = cells;
}

// ── WEEK VIEW
function renderWeekView() {
  const today = new Date();
  const startOfWeek = new Date(today);
  startOfWeek.setDate(today.getDate() - today.getDay() + plannerWeekOffset * 7);
  const endOfWeek = new Date(startOfWeek);
  endOfWeek.setDate(startOfWeek.getDate() + 6);
  const label = `${startOfWeek.toLocaleDateString('en-US',{month:'short',day:'numeric'})} – ${endOfWeek.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}`;
  document.getElementById('week-label').textContent = label;

  const todayStr = formatDateStr(today);
  const weekDates = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(startOfWeek);
    d.setDate(startOfWeek.getDate() + i);
    weekDates.push(d);
  }

  const hours = ['6 AM','7 AM','8 AM','9 AM','10 AM','11 AM','12 PM','1 PM','2 PM','3 PM','4 PM','5 PM','6 PM'];
  const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  let html = `<div class="planner-week-grid">
    <div class="planner-week-hd" style="background:var(--sand);color:var(--muted)"></div>
    ${weekDates.map(d => {
      const ds = formatDateStr(d);
      const isT = ds === todayStr;
      return `<div class="planner-week-hd ${isT?'today-col':''}" onclick="jumpToDay('${ds}')" style="cursor:pointer">
        <div>${dayNames[d.getDay()]}</div>
        <div style="font-size:16px;font-weight:${isT?'700':'500'}">${d.getDate()}</div>
      </div>`;
    }).join('')}`;

  // All-day events row
  const allDayEvs = weekDates.map(d => getEventsForDate(formatDateStr(d)).filter(e => !e.time));
  const hasAllDay = allDayEvs.some(a => a.length > 0);
  if (hasAllDay) {
    html += `<div class="planner-week-time" style="font-size:9px">All day</div>`;
    weekDates.forEach((d, i) => {
      const ds = formatDateStr(d);
      const isT = ds === todayStr;
      html += `<div class="planner-week-cell ${isT?'today-col':''}">
        ${allDayEvs[i].map(e => `<div class="planner-week-event" style="background:${EV_COLORS[e.type]||'var(--euca)'}" onclick="showEventDetail(${e.id})">${e.title}</div>`).join('')}
      </div>`;
    });
  }

  // Hourly rows
  hours.forEach(hr => {
    const hrNum = hr.includes('PM') && !hr.startsWith('12') ? parseInt(hr)+12 : (hr.startsWith('12')&&hr.includes('PM') ? 12 : parseInt(hr));
    const hrStr = String(hrNum).padStart(2,'0') + ':00';
    html += `<div class="planner-week-time">${hr}</div>`;
    weekDates.forEach((d, i) => {
      const ds = formatDateStr(d);
      const isT = ds === todayStr;
      const evs = getEventsForDate(ds).filter(e => e.time && e.time.slice(0,2) === String(hrNum).padStart(2,'0'));
      html += `<div class="planner-week-cell ${isT?'today-col':''}" onclick="quickAddEvent('${ds}','${hrStr}')">
        ${evs.map(e => `<div class="planner-week-event" style="background:${EV_COLORS[e.type]||'var(--euca)'}" onclick="event.stopPropagation();showEventDetail(${e.id})">${e.title}</div>`).join('')}
      </div>`;
    });
  });

  html += '</div>';
  document.getElementById('week-grid').innerHTML = html;
}

// ── DAILY VIEW
function renderDailyView() {
  const today = new Date();
  const ref = new Date(today);
  ref.setDate(today.getDate() + plannerDayOffset);
  const dateStr = formatDateStr(ref);
  const label = ref.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric', year:'numeric'});
  document.getElementById('day-label').textContent = label;

  const evs = getEventsForDate(dateStr);
  const el = document.getElementById('daily-agenda');

  if (!evs.length) {
    el.innerHTML = `<div style="text-align:center;padding:32px;color:var(--muted);border:1.5px dashed var(--border);border-radius:12px;font-size:13px">
      No events for this day.<br><span style="font-size:11px">Click <strong>+ Add to This Day</strong> above or click any time slot in the weekly view.</span>
    </div>`;
    return;
  }

  const timed = evs.filter(e => e.time).sort((a,b) => a.time.localeCompare(b.time));
  const untimed = evs.filter(e => !e.time);

  let html = '';
  if (untimed.length) {
    html += `<div style="margin-bottom:12px"><div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">All Day</div>
    ${untimed.map(e => eventRowHTML(e)).join('')}</div>`;
  }
  if (timed.length) {
    html += `<div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">Scheduled</div>
    ${timed.map(e => eventRowHTML(e)).join('')}`;
  }
  el.innerHTML = html;
}

function eventRowHTML(e) {
  const color = EV_COLORS[e.type] || 'var(--euca)';
  const timeStr = e.time ? `${e.time.slice(0,5)}${e.endTime?' – '+e.endTime.slice(0,5):''}` : '';
  return `<div class="planner-daily-event" style="border-left-color:${color}" onclick="showEventDetail(${e.id})">
    <div style="width:8px;height:8px;border-radius:50%;background:${color};flex-shrink:0"></div>
    <div style="flex:1;min-width:0">
      <div style="font-size:13px;font-weight:600;color:var(--text)">${e.title}</div>
      ${timeStr ? `<div style="font-size:11px;color:var(--muted)">${timeStr}</div>` : ''}
      ${e.notes ? `<div style="font-size:11.5px;color:var(--text-mid);margin-top:2px">${e.notes}</div>` : ''}
    </div>
    <span style="font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;background:${color}22;color:${color};flex-shrink:0">${EV_LABELS[e.type]||e.type}</span>
  </div>`;
}

function showEventDetail(id) {
  loadPlannerEvents();
  const e = plannerEvents.find(x => x.id === id);
  if (!e) return;
  const color = EV_COLORS[e.type] || 'var(--euca)';
  document.getElementById('event-detail-title').innerHTML = `<span style="background:${color};color:#fff;padding:2px 10px;border-radius:6px;font-size:13px;margin-right:8px">${EV_LABELS[e.type]||e.type}</span>${e.title} <button class="modal-close" onclick="closeModal('modal-event-detail')">×</button>`;
  document.getElementById('event-detail-body').innerHTML = `
    <div style="font-size:13px;color:var(--text-mid);margin-bottom:12px">
      📅 ${new Date(e.date+'T00:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'})}
      ${e.time ? ` · ⏰ ${e.time.slice(0,5)}${e.endTime?' – '+e.endTime.slice(0,5):''}` : ''}
      ${e.repeat !== 'none' ? ` · 🔁 Repeats ${e.repeat}` : ''}
    </div>
    ${e.notes ? `<div style="background:var(--euca-fog);border-radius:10px;padding:12px;font-size:13px;line-height:1.6;color:var(--text);margin-bottom:16px">${e.notes}</div>` : ''}
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button class="btn btn-warn btn-sm" onclick="deleteEvent(${e.id})">Delete</button>
      <button class="btn btn-primary btn-sm" onclick="closeModal('modal-event-detail')">Close</button>
    </div>`;
  showModal('modal-event-detail');
}

function quickAddEvent(dateStr, timeStr) {
  document.getElementById('ev-plan-date').value = dateStr;
  document.getElementById('ev-time').value = timeStr;
  showModal('modal-add-event');
}

function jumpToDay(dateStr) {
  const today = new Date();
  const target = new Date(dateStr + 'T00:00:00');
  plannerDayOffset = Math.round((target - new Date(today.getFullYear(), today.getMonth(), today.getDate())) / (1000*60*60*24));
  renderDailyView();
  document.getElementById('planner-daily-section').scrollIntoView({behavior:'smooth', block:'nearest'});
}

function changeMonth(dir) { plannerMonthOffset += dir; renderMonthView(); }
function changeWeek(dir) { plannerWeekOffset += dir; renderWeekView(); }
function changeDay(dir) { plannerDayOffset += dir; renderDailyView(); }
function goToToday() { plannerMonthOffset=0; plannerWeekOffset=0; plannerDayOffset=0; renderPlanner(); }

function renderPlanner() {
  loadPlannerEvents();
  renderMonthView();
  renderWeekView();
  renderDailyView();
  // Set today's date as default for add event
  const dateInput = document.getElementById('ev-plan-date');
  if (dateInput && !dateInput.value) dateInput.valueAsDate = new Date();
}

// ── EXPORT
function exportPlannerData() {
  loadPlannerEvents();
  if (!plannerEvents.length) { showToast('No events to export'); return; }
  // Export as ICS
  let ics = 'BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//Command Center//Planner//EN\r\n';
  plannerEvents.forEach(e => {
    const start = e.date.replace(/-/g,'') + (e.time ? 'T' + e.time.replace(':','') + '00' : '');
    const end = e.date.replace(/-/g,'') + (e.endTime ? 'T' + e.endTime.replace(':','') + '00' : e.time ? 'T' + e.time.replace(':','') + '00' : '');
    ics += `BEGIN:VEVENT\r\nUID:${e.id}@commandcenter\r\nSUMMARY:${e.title}\r\nDTSTART:${start}\r\nDTEND:${end}\r\nDESCRIPTION:${e.notes||''}\r\nEND:VEVENT\r\n`;
  });
  ics += 'END:VCALENDAR';
  const blob = new Blob([ics], {type:'text/calendar'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `planner-export-${new Date().toISOString().slice(0,10)}.ics`;
  a.click();
  showToast('Exported as .ics ✓');
}

// ── UPLOAD / AI IMPORT
async function handlePlannerUpload(file) {
  if (!file) return;
  const previewEl = document.getElementById('planner-upload-preview');
  previewEl.innerHTML = '<div class="ai-box"><span class="spinner"></span> Reading your file and extracting events...</div>';

  try {
    let content = '';
    const isImage = file.type.startsWith('image/');

    if (file.name.endsWith('.ics')) {
      // Parse ICS directly
      const text = await file.text();
      const imported = parseICS(text);
      if (imported.length) {
        showImportPreview(imported, previewEl);
      } else {
        previewEl.innerHTML = '<div style="color:var(--danger);font-size:12.5px">No events found in .ics file.</div>';
      }
      return;
    }

    if (isImage) {
      // Convert image to base64 for AI vision
      const base64 = await new Promise(res => {
        const reader = new FileReader();
        reader.onload = () => res(reader.result.split(',')[1]);
        reader.readAsDataURL(file);
      });
      const mediaType = file.type || 'image/jpeg';

      const response = await fetch('https://kylee-ap-proxy.eduadmin.workers.dev', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({
          system: 'You are a calendar extraction assistant. Extract all events, meetings, deadlines, and appointments from the image. Return ONLY a JSON array with objects containing: title (string), date (YYYY-MM-DD), time (HH:MM 24hr or empty string), endTime (HH:MM or empty string), type (general/meeting/deadline/personal/pd/observation/parent/student), notes (string). Today is ' + new Date().toISOString().slice(0,10) + '. If a year is not shown assume current year. Return only the JSON array, no markdown.',
          messages: [{role:'user', content:[
            {type:'image', source:{type:'base64', media_type:mediaType, data:base64}},
            {type:'text', text:'Extract all events from this calendar/schedule image into JSON.'}
          ]}]
        })
      });
      const data = await response.json();
      const text = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
      const events = JSON.parse(text.replace(/```json|```/g,'').trim());
      showImportPreview(events, previewEl);
      return;
    }

    // PDF / CSV / XLSX
    if (file.name.match(/\.xlsx?|\.csv/i)) {
      const ab = await file.arrayBuffer();
      const wb = XLSX.read(ab, {type:'array'});
      wb.SheetNames.forEach(sn => { content += XLSX.utils.sheet_to_csv(wb.Sheets[sn]) + '\n'; });
    } else if (file.name.endsWith('.pdf')) {
      const ab = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({data:ab}).promise;
      for (let i = 1; i <= Math.min(pdf.numPages, 20); i++) {
        const page = await pdf.getPage(i);
        const tc = await page.getTextContent();
        content += tc.items.map(s=>s.str).join(' ') + '\n';
      }
    } else {
      content = await file.text();
    }

    // Send to AI
    const response = await fetch('https://kylee-ap-proxy.eduadmin.workers.dev', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        system: 'You are a calendar extraction assistant. Extract all events from the provided text. Return ONLY a JSON array with objects: title (string), date (YYYY-MM-DD), time (HH:MM 24hr or empty string), endTime (HH:MM or empty), type (general/meeting/deadline/personal/pd/observation/parent/student), notes (string). Today is ' + new Date().toISOString().slice(0,10) + '. Return only the JSON array, no markdown.',
        messages: [{role:'user', content:'Extract all calendar events from this text:\n\n' + content.slice(0,8000)}]
      })
    });
    const data = await response.json();
    const raw = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    const events = JSON.parse(raw.replace(/```json|```/g,'').trim());
    showImportPreview(events, previewEl);

  } catch(err) {
    previewEl.innerHTML = `<div style="color:var(--danger);font-size:12.5px;padding:10px">Could not read file: ${err.message}. Try a different format or take a clearer photo.</div>`;
  }
}

function parseICS(text) {
  const events = [];
  const evBlocks = text.split('BEGIN:VEVENT').slice(1);
  evBlocks.forEach(block => {
    const get = (key) => { const m = block.match(new RegExp(key + ':(.+)')); return m ? m[1].trim() : ''; };
    const dtstart = get('DTSTART');
    if (!dtstart) return;
    const dateStr = dtstart.slice(0,4)+'-'+dtstart.slice(4,6)+'-'+dtstart.slice(6,8);
    const timeStr = dtstart.length > 8 ? dtstart.slice(9,11)+':'+dtstart.slice(11,13) : '';
    events.push({
      title: get('SUMMARY') || 'Event',
      date: dateStr,
      time: timeStr,
      endTime: '',
      type: 'general',
      notes: get('DESCRIPTION') || ''
    });
  });
  return events;
}

function showImportPreview(events, previewEl) {
  if (!events || !events.length) {
    previewEl.innerHTML = '<div style="color:var(--muted);font-size:12.5px">No events found. Try a different file or photo.</div>';
    return;
  }
  previewEl.innerHTML = `
    <div style="margin-bottom:10px">
      <div style="font-size:13px;font-weight:700;color:var(--euca-deep);margin-bottom:8px">✅ Found ${events.length} event${events.length!==1?'s':''}. Review and confirm:</div>
      <div style="max-height:280px;overflow-y:auto;border:1px solid var(--border);border-radius:10px;margin-bottom:10px">
        ${events.map((e,i) => `
          <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid var(--border-soft)">
            <input type="checkbox" id="imp-ev-${i}" checked style="flex-shrink:0">
            <div style="flex:1;min-width:0">
              <div style="font-size:12.5px;font-weight:600;color:var(--text)">${e.title}</div>
              <div style="font-size:11px;color:var(--muted)">${e.date}${e.time?' · '+e.time:''} · ${EV_LABELS[e.type]||e.type}</div>
            </div>
          </div>`).join('')}
      </div>
      <button class="btn btn-primary" onclick="confirmImport(${JSON.stringify(events).replace(/"/g,'&quot;')})">Import Selected Events</button>
    </div>`;

  // Store events for import
  window._pendingImportEvents = events;
  previewEl.querySelector('.btn').onclick = () => confirmImport(events);
}

function confirmImport(events) {
  const checkboxes = document.querySelectorAll('[id^="imp-ev-"]');
  const toImport = events.filter((e,i) => {
    const cb = document.getElementById(`imp-ev-${i}`);
    return cb ? cb.checked : true;
  });
  loadPlannerEvents();
  toImport.forEach(e => {
    plannerEvents.push({...e, id: Date.now() + Math.random()});
  });
  savePlannerEvents();
  closeModal('modal-planner-upload');
  renderPlanner();
  showToast(`${toImport.length} event${toImport.length!==1?'s':''} imported ✓`);
  document.getElementById('planner-upload-preview').innerHTML = '';
  document.getElementById('planner-file-input').value = '';
}

